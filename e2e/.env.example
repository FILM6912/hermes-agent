# Copy to e2e/.env or export before `npm test` (e2e/.env is gitignored via repo .env.* rules).
#
# Hermes WebUI must already be running — Playwright does not start the server.
# HERMES_E2E_BASE_URL=http://127.0.0.1:8787
#
# Required when auth is enabled (password or multi-user):
# HERMES_E2E_PASSWORD=changeme
# HERMES_E2E_USERNAME=admin
