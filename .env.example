# Hermes Web UI — local machine config template
# Copy this to .env and fill in your values.
#   cp .env.example .env
# start.sh sources .env automatically if present.
# All values are optional — auto-discovery will fill in anything left blank.

# Path to your hermes-agent checkout (the repo that contains run_agent.py)
# HERMES_WEBUI_AGENT_DIR=/path/to/hermes-agent

# Python executable to use (defaults to the agent venv if found)
# HERMES_WEBUI_PYTHON=/path/to/python

# ── Document RAG API (integrated document_api_supabase) ──
# HERMES_WEBUI_DOCUMENT_API_ENABLED=true   # true = เปิด | false = ปิด
# เมื่อไม่ตั้งค่า: เปิดอัตโนมัติเมื่อมี SUPABASE_URL
# See requirements.txt (Document RAG section) and .env.docker.example.
# PG_HOST=127.0.0.1
# PG_PORT=5432
# PG_DATABASE=postgres
# PG_USER=postgres
# PG_PASSWORD=
# PG_SSLMODE=disable
# SUPABASE_URL=http://host:8000
# SUPABASE_SERVICE_KEY=
# Public Supabase Storage objects are proxied at /storage/v1/** on the WebUI port
# (no browser exposure of SUPABASE_SERVICE_KEY). Example:
#   GET http://127.0.0.1:8789/storage/v1/object/public/document-files/.../file.jpeg
# URL รูป/ไฟล์ใน markdown ที่บันทึกใน DB — ใช้ WebUI proxy /storage/v1/ (ไม่ใช่ SUPABASE_URL)
# Stored document markdown/image URLs default to origin-relative paths, e.g.
#   /storage/v1/object/public/document-files/.../file.jpeg
# so they work from any host the user opens WebUI on (localhost, LAN IP, etc.).
# Set only when external systems need an absolute base (alias: DOCUMENT_PUBLIC_BASE_URL).
# RAG search/chunk responses rewrite stored links to this base at read time (no re-ingest).
# HERMES_WEBUI_PUBLIC_URL=http://192.168.99.1:8787
# SUPABASE_STORAGE_BUCKET=document-images
# SUPABASE_TRANSCRIPT_BUCKET=transcript
# SUPABASE_TABLE_NAME=langflow
# SUPABASE_QUERY_NAME=match_documents
# Hugging Face model snapshots — host ./models mounted to /models in Docker
# HERMES_MODELS_DIR=./models
# HF_MODELS_DIR=/models
# Embedding — huggingface (local) or vllm/openai (HTTP)
# EMBEDDING_BACKEND=huggingface
# EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-2B
# EMBEDDING_MODEL_PATH=/models/Qwen3-VL-Embedding-2B
# EMBEDDING_LOAD_BITS=16
# EMBEDDING_DIMENSIONS=2048
# EMBEDDING_API_KEY=EMPTY
# EMBEDDING_BASE_URL=http://host:8101/v1
# Reranker — huggingface (local) or vllm (HTTP)
# RERANKER_ENABLED=true
# RERANKER_BACKEND=huggingface
# RERANKER_MODEL=Qwen/Qwen3-VL-Reranker-2B
# RERANKER_MODEL_PATH=/models/Qwen3-VL-Reranker-2B
# RERANKER_LOAD_BITS=16
# RERANKER_BASE_URL=http://host:8102/v1
# LLM_ENABLED=true
# LLM_BASE_URL=http://host:1234/v1
# ASR_ENABLED=false
# ASR_API_URL=http://192.168.99.1:9786/v1/audio/transcriptions
# ASR_MODEL_ID=FILM6912/monsoon-whisper-medium-gigaspeech2-ct2
# ASR_RESPONSE_FORMAT=verbose_json
#
# Stateless pipeline test API (/api/v1/test/*) — no DB or job persistence
# TEST_PIPELINE_LLM_ORGANIZE_TIMING=before_chunk
#   before_chunk — LLM organize runs on full markdown before chunking
#   after_chunk  — chunk first, then LLM organize on joined chunks
# TEST_PIPELINE_ORGANIZE_MODEL=
#   optional model override for organize step (defaults to LLM_MODEL)
#
# Document MCP (fastapi-mcp) — exposes POST /api/v1/search and GET /api/v1/search/documents
# MCP_ENABLED=true
# MCP_MOUNT_PATH=/mcp
# MCP_API_KEY=your-permanent-service-bearer-key
# MCP_REQUIRE_BEARER=true
# MCP_KM_NUMBER_OF_RESULTS=5
#   Hit count for POST /api/v1/search and MCP search_documents (not a request param).

# ── WebUI server ──
# HERMES_WEBUI_HOST=127.0.0.1
# HERMES_WEBUI_PORT=8787

# File size limits (MB-style env vars; see app/domain/config.py)
# HERMES_WEBUI_MAX_UPLOAD_MB=20
#   Chat/workspace upload cap (default 20 MB).
# HERMES_WEBUI_PREVIEW_MAX_MB=50
#   Inline preview/download via /api/file/raw (PDF, DOCX, XLSX, PPTX, etc.).
#   Text editor reads via /api/file/read stay at 200 KB (MAX_FILE_BYTES).

# Outbound HTTP(S) proxy for server-side provider probes (corporate network).
# HERMES_WEBUI_HTTP_PROXY=http://proxy.company:8080
# HERMES_WEBUI_HTTPS_PROXY=http://proxy.company:8080
# HERMES_WEBUI_NO_PROXY=localhost,127.0.0.1,::1
# Legacy /api catch-alls (default off). Set to 1 for rollback. See docs/phase5-decommission.md.
# HERMES_WEBUI_LEGACY_API=0

# Base directory for all Hermes state (affects workspace paths below)
# HERMES_HOME=~/.hermes

# ── Workspace — one workspace per profile, auto-created ──
# Relative paths resolve under HERMES_HOME (~/.hermes locally, /home/hermeswebui/.hermes in Docker).
HERMES_WEBUI_DEFAULT_WORKSPACE=./workspace
HERMES_WEBUI_PROFILE_WORKSPACE=./workspace
HERMES_WEBUI_WORKSPACE_NAME=Home

# WebUI state directory (relative to HERMES_HOME)
HERMES_WEBUI_STATE_DIR=./webui

# WebUI local config database (default: SQLite at {HERMES_WEBUI_STATE_DIR}/webui.db)
# HERMES_WEBUI_LOCAL_DATABASE_URL=sqlite:////path/to/webui.db
#
# Settings, users, auth sessions, and webui_history use Supabase/PostgreSQL when PG_* is set
# (same vars as document API below) or via an explicit URL. When Supabase is configured,
# users/sessions/settings are stored in normalized tables (webui_users, webui_sessions,
# webui_departments, webui_roles, webui_settings) instead of webui_kv JSON blobs after first startup migration.
# HERMES_WEBUI_SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:6543/postgres

# Optional: use an absolute workspace path instead of ./workspace
# HERMES_WEBUI_DEFAULT_WORKSPACE=/home/me/projects/my-app
# HERMES_WEBUI_PROFILE_WORKSPACE=/home/me/projects/my-app

# ── Other ──
# Optional model override. Leave unset to use the active Hermes provider default.
# HERMES_WEBUI_DEFAULT_MODEL=

# Path to your Hermes config.yaml (for toolsets and model config)
# HERMES_CONFIG_PATH=~/.hermes/config.yaml

# Display name for the assistant in the UI (default: Hermes)
# HERMES_WEBUI_BOT_NAME=Hermes

# ── Multi-user login (optional) ─────────────────────────────────────────────
# Enable per-user accounts (admin + regular users).
#
# HERMES_WEBUI_ADMIN_USER and HERMES_WEBUI_ADMIN_PASSWORD are ONLY for the
# single default admin created on first install when users.json is missing.
# HERMES_WEBUI_ADMIN_USER may be an email address (e.g. admin@example.com).
# HERMES_WEBUI_ADMIN_DISPLAY_NAME sets the bootstrap admin's display name.
# They are ignored after users.json exists (restart does not recreate users).
# Add, edit, or delete all other accounts in the WebUI: Settings → Users
# (admin login required). There is no self-registration endpoint.
#
# เปิด multi-user login (แยกบัญชี admin / user).
# สองตัวแปร HERMES_WEBUI_ADMIN_* ใช้เฉพาะสร้าง admin คนแรกครั้งเดียวตอนยังไม่มี
# users.json — restart จะไม่เขียนทับ user ที่มีอยู่
# user คนอื่นให้สร้างใน Settings → Users หลัง login เป็น admin (ไม่มีสมัครเอง)
#
# Change HERMES_WEBUI_ADMIN_PASSWORD before exposing the server on a network.
# เปลี่ยนรหัสผ่านก่อนเปิดให้เข้าถึงจากเครือข่ายภายนอก
#
# To reset accounts: delete {HERMES_WEBUI_STATE_DIR}/users.json and restart,
# OR run: python3 scripts/promote_multi_user_admin.py
# รีเซ็ตบัญชี: ลบ users.json แล้ว restart หรือใช้ promote script ด้านบน
HERMES_WEBUI_MULTI_USER=1
HERMES_WEBUI_ADMIN_USER=admin@example.com
HERMES_WEBUI_ADMIN_DISPLAY_NAME=Administrator
HERMES_WEBUI_ADMIN_PASSWORD=changeme

INGEST_MAX_PARALLEL_FILES=5
