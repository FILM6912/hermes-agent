# Hermes Web UI — Docker Compose configuration template
#
# Copy this file to `.env` next to your docker-compose.yml.
# All variables are optional — Docker Compose substitutes defaults if unset.
#
#   cp .env.docker.example .env
#   # edit values you care about, then:
#   docker compose up -d --build
#
# After pulling UI changes, rebuild the image so static/dist is baked in:
#   docker compose build --no-cache && docker compose up -d --force-recreate
# Do not set HERMES_WEBUI_UI=legacy unless you intentionally want the old shell.

# ──────────────────────────────────────────────────────────────────────────
# UID / GID — host user mapping
# ──────────────────────────────────────────────────────────────────────────
# Critical when bind-mounting an EXISTING host directory (e.g. ~/.hermes).
# The container runs as UID/GID and must match your host file ownership,
# otherwise the container can't read your config.yaml or write sessions.
#
# Find yours:   id -u   (UID)   |   id -g   (GID)
#
# On macOS, UIDs start at 501 (not 1000), so you MUST set these.
# On Linux, the default of 1000 usually matches the first interactive user.
#
# REPLACE THESE WITH YOUR ACTUAL VALUES (run `id -u` and `id -g`):
UID=1000
GID=1000

# ──────────────────────────────────────────────────────────────────────────
# Hermes home directory (shared by hermes-agent + hermes-webui)
# ──────────────────────────────────────────────────────────────────────────
# docker-compose.yml bind-mounts this HOST path to both containers.
# Default: ./hermes next to docker-compose.yml (create with: mkdir -p hermes)
# Migrate an existing install:  cp -a ~/.hermes/. ./hermes/
# Legacy host path: HERMES_HOME=${HOME}/.hermes
#
# NOTE: compose sets in-container HERMES_HOME=/home/hermeswebui/.hermes explicitly.
# Do not rely on this value inside the WebUI container — relative paths like ./webui
# resolve against the in-container home, not ./hermes on the host.
HERMES_HOME=./hermes

# Gateway API port (hermes-agent container; host network binds this on the host)
# HERMES_GATEWAY_PORT=8642
#
# With docker-compose.yml host networking, LLM/custom provider URLs in config.yaml
# can use the same host addresses as on the machine (e.g. http://192.168.99.1:4000/v1
# or http://127.0.0.1:4000/v1). Bridge-network host.docker.internal is not required.

# ──────────────────────────────────────────────────────────────────────────
# WebUI server
# ──────────────────────────────────────────────────────────────────────────
# HERMES_WEBUI_HOST=0.0.0.0
# HERMES_WEBUI_PORT=8787

# File size limits (MB-style env vars; see app/domain/config.py)
# HERMES_WEBUI_MAX_UPLOAD_MB=20
#   Chat/workspace upload cap (default 20 MB).
# HERMES_WEBUI_PREVIEW_MAX_MB=50
#   Inline preview/download via /api/file/raw (PDF, DOCX, XLSX, PPTX, etc.).
#   Text editor reads via /api/file/read stay at 200 KB (MAX_FILE_BYTES).

# Settings, users, auth sessions, and webui_history use PG_* (Supabase Postgres).
# workspaces/projects stay in local SQLite ({HERMES_WEBUI_STATE_DIR}/webui.db).
# Hugging Face snapshots — bind-mount host models dir (see docker-compose.yml)
# HERMES_MODELS_DIR=./models
# HF_MODELS_DIR=/models
# mkdir -p models && ./scripts/download-embedding-models.sh
# First hub download also caches under ./models/hub when HF_HOME=/models (compose default).
# Layout example:
#   ./models/Qwen3-VL-Embedding-2B/
#   ./models/Qwen3-VL-Reranker-2B/
#   ./models/hub/models--Qwen--Qwen3-VL-Embedding-2B/snapshots/<rev>/
# GPU for local Hugging Face embedding/reranker/ASR:
#   docker compose up -d --build   # requests all GPUs on hermes-webui by default
# Host needs NVIDIA driver + NVIDIA Container Toolkit for CUDA inside the container.
# Hosts without NVIDIA may warn at `up` time; embedding falls back to CPU when CUDA
# is unavailable. Explicit CPU-only:
#   docker compose -f docker-compose.yml -f docker-compose.cpu.yml up -d --build
# No EMBEDDING_DEVICE env — code uses device_map=auto when CUDA is visible in the container.
#
# Legacy document/RAG settings removed.

# ──────────────────────────────────────────────────────────────────────────
# Outbound HTTP(S) proxy (corporate network)
# ──────────────────────────────────────────────────────────────────────────
# HERMES_WEBUI_HTTP_PROXY=http://proxy.company:8080
# HERMES_WEBUI_HTTPS_PROXY=http://proxy.company:8080
# HERMES_WEBUI_NO_PROXY=localhost,127.0.0.1,host.docker.internal

# ──────────────────────────────────────────────────────────────────────────
# CORS / allowed origins (optional)
# ──────────────────────────────────────────────────────────────────────────
# HERMES_WEBUI_ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173,http://192.168.99.1:8787

# ──────────────────────────────────────────────────────────────────────────
# Workspace — all settings configurable here
# ──────────────────────────────────────────────────────────────────────────
# Where WebUI stores sessions, workspace lists, and UI state inside the container.
# Relative paths (./webui) resolve under HERMES_HOME (/home/hermeswebui/.hermes).
HERMES_WEBUI_STATE_DIR=./webui

# Default boot-time workspace fallback. Supports profile-relative paths such as
# ./workspace (resolved under HERMES_HOME) or an absolute in-container path.
HERMES_WEBUI_DEFAULT_WORKSPACE=./workspace

# Per-profile workspace path stored in each profile's config.yaml and workspaces.json.
# Defaults to HERMES_WEBUI_DEFAULT_WORKSPACE when unset.
HERMES_WEBUI_PROFILE_WORKSPACE=./workspace

# Display name shown in the Spaces sidebar for the auto-created workspace.
HERMES_WEBUI_WORKSPACE_NAME=Home

# Workspace bind mount (host path → container path). docker-compose.yml mounts
# HERMES_WORKSPACE to /workspace by default (${HOME}/workspace on the host).
HERMES_WORKSPACE=./workspace
#
# Legacy absolute in-container mount:
# HERMES_WORKSPACE=${HOME}/my-project
# HERMES_WEBUI_WORKSPACE_MOUNT=/workspace
# HERMES_WEBUI_DEFAULT_WORKSPACE=/workspace
# HERMES_WEBUI_PROFILE_WORKSPACE=/workspace

# ──────────────────────────────────────────────────────────────────────────
# Skills hub — GitHub API token (preview / install from skills.sh)
# ──────────────────────────────────────────────────────────────────────────
# skills.sh search uses the skills.sh API (no token). Preview and install
# resolve the underlying GitHub repo via the GitHub Contents API. Without a
# token the limit is 60 requests/hour per container IP — browsing the hub can
# exhaust it quickly.
#
# Add a fine-grained PAT (public repo read is enough) or run `gh auth login`
# on the host and pass the token here. WebUI reads GITHUB_TOKEN / GH_TOKEN via
# env_file (.env). Unauthenticated installs fall back to `npx skills add`
# (git clone) when the hub CLI hits the rate limit.
#
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────────────────────────────
# Local model servers (LM Studio, Ollama) — Docker reachability
# ──────────────────────────────────────────────────────────────────────────
# Hermes in Docker cannot reach services on the host via 127.0.0.1 or localhost;
# those addresses refer to the container itself. docker-compose.yml adds
# extra_hosts so host.docker.internal resolves to the host gateway.
#
# Configure the OpenAI-compatible base URL in mounted Hermes state (not here):
#   ~/.hermes/config.yaml  →  providers.lmstudio.base_url  or  model.base_url
#   ~/.hermes/.env         →  LM_BASE_URL (optional; agent CLI env mirror)
#
# Typical values when LM Studio runs on the same machine as Docker:
#   http://host.docker.internal:1234/v1     (LM Studio default port)
#   http://host.docker.internal:11434/v1    (Ollama)
#
# On Linux without extra_hosts, use the host LAN IP instead (e.g. http://192.168.x.x:1234/v1).
# Verify from inside the container:
#   docker compose exec hermes-webui curl -sS http://host.docker.internal:1234/v1/models | head
#
# Full onboarding Base URL rules: docs/onboarding.md

# ──────────────────────────────────────────────────────────────────────────
# Password — protect remote access
# ──────────────────────────────────────────────────────────────────────────
# REQUIRED if you expose the container on anything other than 127.0.0.1.
# Without a password, anyone who can reach the port can run commands as
# the agent.
# HERMES_WEBUI_PASSWORD=change-me-to-something-strong

# Session token TTL (supports: s, m, h, d, y; min 60 seconds, max 10 years)
# Examples: 55s, 10m, 12h, 30d, 1y 8d
HERMES_WEBUI_SESSION_TTL=30d

# Models discovery responsiveness
# Reduce how long /api/v1/models waits on slow provider catalogs.
HERMES_WEBUI_MODELS_LIVE_TIMEOUT=4
HERMES_WEBUI_MODELS_CACHE_WAIT_TIMEOUT=8
# Avoid ~4s Bedrock/IMDS stall on every /api/models cold build (Docker/LAN without IAM).
AWS_EC2_METADATA_DISABLED=true
# In-memory catalog cache seconds (default 86400; compose uses 60). Disk cache stays on.
# HERMES_WEBUI_MODELS_CACHE_TTL=60
# Browser chat retries (default 1): surface provider errors instead of waiting on 429 backoffs
HERMES_WEBUI_API_MAX_RETRIES=1

# ──────────────────────────────────────────────────────────────────────────
# Multi-user mode — per-user accounts (admin + regular users)
# ──────────────────────────────────────────────────────────────────────────
# Enable when you want separate logins per person (1 regular user : 1 profile).
# HERMES_WEBUI_ADMIN_USER / HERMES_WEBUI_ADMIN_PASSWORD apply ONLY on first install
# when users.json is absent; restarts never overwrite existing users.
# HERMES_WEBUI_ADMIN_USER may be an email address; HERMES_WEBUI_ADMIN_DISPLAY_NAME
# sets the bootstrap admin display name (Settings → Account).
# Create additional users after admin login: Settings → Users (no self-register).
#
# เปิด multi-user login (แยกบัญชี admin / user).
# HERMES_WEBUI_ADMIN_* ใช้สร้าง admin คนแรกครั้งเดียวเมื่อยังไม่มี users.json
# restart ไม่เขียนทับ user — user เพิ่มที่ Settings → Users (ไม่มีสมัครเอง)
#
# Change HERMES_WEBUI_ADMIN_PASSWORD before exposing the port on a network.
# เปลี่ยนรหัสผ่านก่อนเปิดให้เข้าถึงจากเครือข่ายภายนอก
HERMES_WEBUI_MULTI_USER=1
HERMES_WEBUI_ADMIN_USER=admin@example.com
HERMES_WEBUI_ADMIN_DISPLAY_NAME=Administrator
HERMES_WEBUI_ADMIN_PASSWORD=changeme
#
# Reset accounts (wrong users / forgot password):
# รีเซ็ตบัญชี (user ผิด / ลืมรหัสผ่าน):
#   1. Stop container, delete {HERMES_WEBUI_STATE_DIR}/users.json under HERMES_HOME
#      (default: ~/.hermes/webui/users.json), then docker compose up -d
#   2. OR promote without deleting: python3 scripts/promote_multi_user_admin.py
#   3. OR POST /api/v1/system/bootstrap-admin with admin + current passwords
#
# After login as admin, create additional users (e.g. "film") in Settings → Users.
# หลัง login เป็น admin แล้ว สร้าง user เพิ่ม (เช่น "film") ได้ที่ Settings → Users

# ──────────────────────────────────────────────────────────────────────────
# Permission handling for bind-mounted .hermes — advanced
# ──────────────────────────────────────────────────────────────────────────
# By default, the WebUI's startup credential-permission fixer enforces
# 0600 mode on .env, auth.json, and similar credential files in HERMES_HOME.
# This is the right behavior on a clean install, but it can clash with:
#
#   - Bind-mounting an EXISTING ~/.hermes whose .env is intentionally 0640
#     (e.g. group-readable for a Docker user group)
#   - HERMES_HOME_MODE configured at the agent level for a multi-user setup
#
# To bypass the WebUI's fixer entirely:
# HERMES_SKIP_CHMOD=1
#
# OR to allow group bits while still stripping world-readable:
# HERMES_HOME_MODE=0640
#
# ⚠️ MULTI-CONTAINER WARNING: HERMES_HOME_MODE has DIFFERENT semantics in
# the WebUI vs. the agent image:
#   - WebUI: credential FILE mode threshold (0640 = allow group bits)
#   - Agent: HERMES_HOME *directory* mode (default 0700)
# 0640 on a directory has NO execute bit, so the agent can't enter its own
# home → broken. If you set HERMES_HOME_MODE for a multi-container setup,
# use 0750 (group-traversable) or 0701 (x-only for non-owner traversal).
# The compose files document both correctly per-service.

# ──────────────────────────────────────────────────────────────────────────
# Multi-container only — used by docker-compose.two-container.yml and
# docker-compose.three-container.yml
# ──────────────────────────────────────────────────────────────────────────
# These compose files use named Docker volumes by default (recommended).
# Set the variables above to your host UID/GID — both the agent container
# (HERMES_UID/HERMES_GID) and the webui container (WANTED_UID/WANTED_GID)
# are derived from $UID/$GID so files written by one are readable by the
# other.
#
# If you switch to bind mounts (replacing `hermes-home: {}` with a `device:`
# bind), ALL THREE containers must mount the SAME host path and run as the
# SAME UID/GID. Mismatched UIDs → "Permission denied" → the WebUI crashes
# on every HTTP request because it can't read its own auth signing key.
